---
type TocItem = {
  depth: number
  slug: string
  text: string
}

type Props = {
  items: TocItem[]
}

const { items } = Astro.props
const toc = items.filter((item) => item.depth >= 2 && item.depth <= 4)
---

{
  toc.length > 0 && (
    <nav
      data-toc-root
      class="no-scrollbar sticky top-[calc(var(--header-height)+1rem)] max-h-[calc(100svh-var(--header-height)-2rem)] overflow-y-auto pb-8"
      aria-label="Table of contents"
    >
      <p class="mb-3 text-xs font-medium tracking-wide text-muted-foreground uppercase">On This Page</p>
      <ul class="space-y-1">
        {toc.map((item) => (
          <li>
            <a
              href={`#${item.slug}`}
              data-toc-link
              data-slug={item.slug}
              data-depth={item.depth}
              class="block rounded-md py-1 text-sm text-muted-foreground transition-colors hover:text-foreground data-[active=true]:font-medium data-[active=true]:text-foreground data-[depth=3]:pl-3 data-[depth=4]:pl-6"
            >
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script is:inline>
  const tocRoots = document.querySelectorAll("[data-toc-root]")

  for (const root of tocRoots) {
    const links = Array.from(root.querySelectorAll("[data-toc-link]"))
    const headingIds = links
      .map((link) => link.getAttribute("data-slug"))
      .filter((slug) => typeof slug === "string" && slug.length > 0)

    if (!headingIds.length) {
      continue
    }

    const updateActiveLink = (activeId) => {
      for (const link of links) {
        const slug = link.getAttribute("data-slug")
        link.dataset.active = slug === activeId ? "true" : "false"
      }
    }

    let activeId = headingIds[0]
    updateActiveLink(activeId)

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activeId = entry.target.id
          }
        }

        updateActiveLink(activeId)
      },
      { rootMargin: "0% 0% -80% 0%" }
    )

    for (const headingId of headingIds) {
      const element = document.getElementById(headingId)

      if (element) {
        observer.observe(element)
      }
    }
  }
</script>
