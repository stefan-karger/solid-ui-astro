---
import { getComponentLinks } from "~/lib/docs"

const components = await getComponentLinks()
---

<div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-x-8 lg:gap-x-16 lg:gap-y-6 xl:gap-x-20">
  {components.map((component) => (
    <a
      href={component.href}
      class="inline-flex items-center gap-2 text-base font-medium text-foreground underline-offset-4 hover:underline"
    >
      {component.title}
    </a>
  ))}
</div>
