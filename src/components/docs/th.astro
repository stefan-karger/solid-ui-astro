---
import { cn } from "~/lib/utils"

interface Props extends Record<string, unknown> {
  class?: string
}

const { class: className, ...props } = Astro.props as Props
---

<th
  class={cn(
    "px-4 py-2 text-left font-bold [&[align=center]]:text-center [&[align=right]]:text-right",
    className
  )}
  {...props}
>
  <slot />
</th>
