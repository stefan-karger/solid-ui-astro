---
import { getIconForLanguageExtension } from "~/components/icons"
import { cn } from "~/lib/utils"

interface Props extends Record<string, unknown> {
  class?: string
  "data-language"?: string
}

const { class: className, ...props } = Astro.props as Props
const language = typeof props["data-language"] === "string" ? props["data-language"] : undefined
const LanguageIcon = getIconForLanguageExtension(language ?? "")
---

<figcaption
  class={cn(
    "flex items-center gap-2 text-code-foreground [&_svg]:size-4 [&_svg]:text-code-foreground [&_svg]:opacity-70",
    className
  )}
  {...props}
>
  <LanguageIcon />
  <slot />
</figcaption>
