---
import type { HTMLAttributes } from "astro/types"

import { CodeBlockCommand } from "~/components/code-block-command"
import { CopyButton } from "~/components/copy-button"
import { cn } from "~/lib/utils"

type Props = HTMLAttributes<"code"> & {
  __raw__?: string
  __src__?: string
  __npm__?: string
  __yarn__?: string
  __pnpm__?: string
  __bun__?: string
}

const {
  class: className,
  __raw__: code,
  __src__: src,
  __npm__: npm,
  __yarn__: yarn,
  __pnpm__: pnpm,
  __bun__: bun,
  ...props
} = Astro.props

const commandProps =
  npm && yarn && pnpm && bun
    ? {
        __npm__: npm,
        __yarn__: yarn,
        __pnpm__: pnpm,
        __bun__: bun
      }
    : undefined

const isCommandBlock = Boolean(commandProps)
const hasRawCode = Boolean(code)
const isInline = !hasRawCode && !isCommandBlock
const blockCodeContent =
  !isInline && !isCommandBlock ? (await Astro.slots.render("default")).trim() : ""
---

{
  isInline ? (
    <code
      class={cn(
        "relative rounded-md bg-muted px-[0.3rem] py-[0.2rem] font-mono text-[0.8rem] wrap-break-word outline-none",
        className
      )}
      {...props}
    >
      <slot />
    </code>
  ) : commandProps ? (
    <CodeBlockCommand client:only="solid-js" {...commandProps} />
  ) : (
    <>
      {code && <CopyButton client:load value={code} src={src} />}
      <code class={className} set:html={blockCodeContent} {...props} />
    </>
  )
}
